---
const year = new Date().getFullYear();

const services = [
  { label: 'Driveways',                  href: '/services#driveways' },
  { label: 'Patios & Walkways',          href: '/services#patios-walkways' },
  { label: 'Garage & Shop Floors',       href: '/services#garage-floors' },
  { label: 'Parking Lots & Lots',        href: '/services#parking-lots' },
  { label: 'Foundations & Slabs',        href: '/services#foundations-slabs' },
  { label: 'Concrete Repair',            href: '/services#concrete-repair' },
];
---

<footer class="bg-navy text-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">

      <!-- Brand Column -->
      <div>
        <a href="/">
          <img
            src="/img/ortega-and-sons--logo.png"
            alt="Ortega & Sons Concrete"
            class="h-auto w-[150px] mb-5 bg-cream p-4"
            style="border-radius: 12px;"
          />
        </a>
        <p class="text-cream/65 text-sm leading-relaxed mb-5">
          Family-owned and operated, Ortega &amp; Sons Concrete delivers expert
          residential and commercial concrete work throughout the Wichita, KS area.
          Quality craftsmanship on every pour.
        </p>
        <!-- Social placeholder -->
        <div class="flex gap-3">
          <a href="https://www.facebook.com/p/Ortega-Sons-Concrete-61564770350622/" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
            class="w-9 h-9 rounded-brand border border-gold/40 flex items-center justify-center text-cream/60 hover:text-beige hover:border-beige transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/p/DWUhDAuiYlO/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
            class="w-9 h-9 rounded-brand border border-gold/40 flex items-center justify-center text-cream/60 hover:text-beige hover:border-beige transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-heading text-beige uppercase tracking-wider text-lg mb-5">
          Our Services
        </h3>
        <ul class="space-y-2">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-cream/65 hover:text-beige transition-colors text-sm flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-gold flex-shrink-0"></span>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-heading text-beige uppercase tracking-wider text-lg mb-5">
          Contact Us
        </h3>
        <ul class="space-y-4 text-sm text-cream/65">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-beige mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>1717 S Main St, Wichita, KS 67213</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-beige mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
            </svg>
            <a href="tel:3168069150" class="hover:text-beige transition-colors">(316) 806-9150</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-beige mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:ortegaandsonsconcrete@gmail.com" class="hover:text-beige transition-colors">
              ortegaandsonsconcrete@gmail.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-beige mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Mon–Fri: 7:00am – 5:00pm</span>
          </li>
        </ul>

        <div class="mt-6">
          <a href="/contact" class="btn btn-gold text-sm py-2.5 px-5">
            Free Estimate
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gold/20 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-cream/35 text-xs text-center">
      <p>&copy; {year} Ortega &amp; Sons Concrete. All rights reserved.</p>
      <p>Website design &amp; development by <a href="https://selahcreate.com" target="_blank" rel="noopener noreferrer" class="text-cream/50 hover:text-beige transition-colors underline underline-offset-2">Selah Create: Digital Design</a></p>
      <p>Wichita, KS &middot; Licensed, Bonded &amp; Insured</p>
    </div>
  </div>
</footer>
