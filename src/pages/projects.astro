---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&q=80',
    category: 'residential',
    categoryLabel: 'Residential',
    title: 'Stamped Concrete Driveway',
    location: 'East Wichita, KS',
    desc: 'Double-wide stamped concrete driveway with ashlar slate pattern and walnut stain. Includes decorative border and concrete sealer.',
    sqft: '980 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=800&q=80',
    category: 'commercial',
    categoryLabel: 'Commercial',
    title: 'Distribution Warehouse Slab',
    location: 'Wichita, KS',
    desc: 'Reinforced concrete slab for a new distribution warehouse, including loading dock aprons and exterior truck approach.',
    sqft: '18,000 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1523413555609-be67a1ede53e?auto=format&fit=crop&w=800&q=80',
    category: 'residential',
    categoryLabel: 'Residential',
    title: 'Backyard Patio &amp; Steps',
    location: 'Derby, KS',
    desc: 'Custom exposed aggregate patio with a two-step transition to lawn grade and a connecting walkway to the side gate.',
    sqft: '640 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1565008447742-97f6f38c985c?auto=format&fit=crop&w=800&q=80',
    category: 'commercial',
    categoryLabel: 'Commercial',
    title: 'Retail Strip Mall Parking Lot',
    location: 'Andover, KS',
    desc: 'Full concrete parking lot replacement for an 8-unit retail strip center, with ADA-compliant curbs, ramps, and accessible stalls.',
    sqft: '24,000 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=800&q=80',
    category: 'residential',
    categoryLabel: 'Residential',
    title: 'Garage Floor &amp; Apron',
    location: 'Maize, KS',
    desc: 'Three-car garage floor with vapor barrier, rebar reinforcement, smooth trowel finish, and a new concrete apron.',
    sqft: '720 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1590725140246-20acddc1ec6d?auto=format&fit=crop&w=800&q=80',
    category: 'commercial',
    categoryLabel: 'Commercial',
    title: 'Auto Dealership Lot Expansion',
    location: 'Wichita, KS',
    desc: 'Concrete inventory display area expansion with heavy-duty reinforcement for vehicle display, including ornamental curbing.',
    sqft: '11,500 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&q=80',
    category: 'residential',
    categoryLabel: 'Residential',
    title: 'Decorative Walkway System',
    location: 'Goddard, KS',
    desc: 'Front-to-back concrete walkway with stamped borders, broom-finish center, and landscape lighting conduit chase.',
    sqft: '320 sq ft',
  },
  {
    img: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=800&q=80',
    category: 'commercial',
    categoryLabel: 'Commercial',
    title: 'Church Campus Sidewalks',
    location: 'Valley Center, KS',
    desc: 'Full perimeter sidewalk replacement and new interior walkway network connecting multiple campus buildings.',
    sqft: '5,200 sq ft',
  },
];
---

<Layout title="Projects" description="View completed concrete projects by Ortega & Sons Concrete — driveways, commercial slabs, patios, and more in Wichita, KS.">

  <!-- ─── PAGE HERO ─────────────────────────────────────────── -->
  <section class="relative h-72 sm:h-96 flex items-end overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=1800&q=80"
      alt="Completed concrete project"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="page-hero-overlay absolute inset-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 w-full">
      <span class="section-label">Portfolio</span>
      <h1 class="font-heading text-cream text-4xl sm:text-5xl font-bold mt-1">Our Projects</h1>
    </div>
  </section>

  <!-- ─── FILTER + GRID ─────────────────────────────────────── -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Filter Buttons -->
      <div class="flex flex-wrap gap-3 mb-12 justify-center">
        <button
          data-filter="all"
          class="btn btn-primary text-sm py-2 px-5"
        >
          All Projects
        </button>
        <button
          data-filter="residential"
          class="btn btn-outline-navy text-sm py-2 px-5"
        >
          Residential
        </button>
        <button
          data-filter="commercial"
          class="btn btn-outline-navy text-sm py-2 px-5"
        >
          Commercial
        </button>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-7">
        {projects.map(p => (
          <div data-category={p.category} class="brand-card bg-white group flex flex-col">
            <div class="overflow-hidden rounded-t-brand">
              <img
                src={p.img}
                alt={p.title}
                class="project-img group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center justify-between mb-2">
                <span class="font-heading text-xs uppercase tracking-widest text-gold">{p.categoryLabel}</span>
                <span class="font-heading text-xs text-navy/40 uppercase tracking-wide">{p.sqft}</span>
              </div>
              <h3 class="font-heading text-navy text-base font-semibold mb-2" set:html={p.title} />
              <p class="text-navy/55 text-xs leading-relaxed mb-3 flex-1">{p.desc}</p>
              <div class="flex items-center gap-1.5 mt-auto">
                <svg class="w-3.5 h-3.5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-navy/45 text-xs font-heading uppercase tracking-wide">{p.location}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────── -->
  <section class="py-20 bg-navy">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="section-label">Start Your Project</span>
      <h2 class="font-heading text-cream text-4xl font-bold mt-1 mb-5">
        Your Project Could Be<br />
        <span class="text-beige">Next on This Page</span>
      </h2>
      <p class="text-cream/65 mb-8 leading-relaxed">
        Contact us for a free estimate. We'll visit the site, answer your
        questions, and give you a clear picture of what to expect.
      </p>
      <a href="/contact" class="btn btn-gold">Get a Free Estimate</a>
    </div>
  </section>

</Layout>
