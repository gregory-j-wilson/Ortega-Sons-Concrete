---
import Layout from '../layouts/Layout.astro';

// Gallery items — photos and videos mixed in. Videos autoplay silently.
const gallery = [
  { type: 'photo', src: '/img/front-driveway.jpeg',            alt: 'Finished concrete driveway' },
  { type: 'photo', src: '/img/hexagon-back-porch.jpeg',        alt: 'Hexagon pattern back porch' },
  { type: 'video', src: '/img/laying-concrete-vid.mp4',        alt: 'Laying concrete' },
  { type: 'photo', src: '/img/criss-cross-driveway.jpeg',      alt: 'Criss-cross pattern driveway' },
  { type: 'photo', src: '/img/back-patio.jpeg',                alt: 'Backyard patio' },
  { type: 'photo', src: '/img/shiny-driveway.jpeg',            alt: 'Smooth shiny driveway finish' },
  { type: 'photo', src: '/img/back-stone-porch-with-border.jpeg', alt: 'Stone porch with decorative border' },
  { type: 'video', src: '/img/smoothing-concrete.mp4',         alt: 'Smoothing concrete finish' },
  { type: 'photo', src: '/img/patio.jpeg',                     alt: 'Concrete patio' },
  { type: 'photo', src: '/img/circular-concrete-porch.jpeg',   alt: 'Circular concrete porch' },
  { type: 'photo', src: '/img/concrete-foundation-bars.jpeg',  alt: 'Concrete foundation with rebar' },
  { type: 'photo', src: '/img/red-smooth-driveway.jpeg',       alt: 'Red smooth driveway' },
  { type: 'video', src: '/img/driveway-laid-vid.mp4',          alt: 'Driveway being laid' },
  { type: 'photo', src: '/img/back-porch.jpeg',                alt: 'Back porch concrete' },
  { type: 'photo', src: '/img/poolside.jpeg',                  alt: 'Poolside concrete' },
  { type: 'photo', src: '/img/front-walkway.jpeg',             alt: 'Front walkway' },
  { type: 'photo', src: '/img/back-shiny-stone-porch.jpeg',    alt: 'Shiny stone porch' },
  { type: 'video', src: '/img/concrete-truck-vid.mp4',         alt: 'Concrete truck delivery' },
  { type: 'photo', src: '/img/stone-driveway.jpeg',            alt: 'Stone finish driveway' },
  { type: 'photo', src: '/img/patio2.jpeg',                    alt: 'Decorative patio' },
  { type: 'photo', src: '/img/making-garage-driveway.jpeg',    alt: 'Garage driveway in progress' },
  { type: 'photo', src: '/img/back-porch-criss-cross.jpeg',    alt: 'Criss-cross back porch' },
  { type: 'video', src: '/img/bobcat-machine-moving-dirt.mp4', alt: 'Bobcat site prep' },
  { type: 'photo', src: '/img/front-porch.jpeg',               alt: 'Front porch concrete' },
  { type: 'photo', src: '/img/shiny-stone-walkway.jpeg',       alt: 'Shiny stone walkway' },
  { type: 'photo', src: '/img/garage-driveway.jpeg',           alt: 'Garage driveway' },
  { type: 'photo', src: '/img/back-smooth-porch.jpeg',         alt: 'Smooth back porch' },
  { type: 'video', src: '/img/crane-concrete-dump-vid.mp4',    alt: 'Crane concrete pour' },
  { type: 'photo', src: '/img/side-driveway.jpeg',             alt: 'Side driveway' },
  { type: 'photo', src: '/img/shed-porch.jpeg',                alt: 'Shed porch concrete' },
  { type: 'photo', src: '/img/laying-concrete-more-done.jpeg', alt: 'Concrete pour in progress' },
  { type: 'photo', src: '/img/back-square-blocks-porch.jpeg',  alt: 'Square block pattern porch' },
  { type: 'video', src: '/img/laying-driveway-vid.mp4',        alt: 'Laying driveway concrete' },
  { type: 'photo', src: '/img/front-walkway-2.jpeg',           alt: 'Front walkway detail' },
  { type: 'photo', src: '/img/crane.jpeg',                     alt: 'Crane on job site' },
  { type: 'photo', src: '/img/making-garage-driveway-2.jpeg',  alt: 'Garage driveway pour' },
  { type: 'photo', src: '/img/concrete-truck-pic.jpeg',        alt: 'Concrete truck on site' },
  { type: 'video', src: '/img/sidewalk-frame-concrete-dump-vid.mp4', alt: 'Sidewalk concrete pour' },
  { type: 'photo', src: '/img/laying-concrete-pic.jpeg',       alt: 'Laying concrete flatwork' },
  { type: 'photo', src: '/img/building-sidewalk.jpeg',         alt: 'Building a sidewalk' },
  { type: 'photo', src: '/img/concrete-machine.jpeg',          alt: 'Concrete machine at work' },
  { type: 'photo', src: '/img/rita-crane.jpeg',                alt: 'Crane job site' },
  { type: 'video', src: '/img/smoothing-concrete-2.mp4',       alt: 'Finishing concrete surface' },
  { type: 'photo', src: '/img/laying-concrete-cones.jpeg',     alt: 'Concrete pour with traffic cones' },
  { type: 'photo', src: '/img/concrete-bars-cones.jpeg',       alt: 'Rebar and cones on site' },
];
---

<Layout title="Project Gallery" description="Browse photos and videos of completed concrete projects by Ortega & Sons Concrete — driveways, patios, foundations, and more in Wichita, KS.">

  <!-- ─── PAGE HERO ─────────────────────────────────────────── -->
  <section class="relative h-72 sm:h-96 flex items-end overflow-hidden">
    <video
      autoplay muted loop playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/img/driveway-laid-vid.mp4" type="video/mp4" />
    </video>
    <div class="page-hero-overlay absolute inset-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 w-full">
      <span class="section-label">Our Work</span>
      <h1 class="font-heading text-cream text-4xl sm:text-5xl font-bold mt-1">Project Gallery</h1>
    </div>
  </section>

  <!-- ─── GALLERY GRID ──────────────────────────────────────── -->
  <section class="py-16 bg-navy">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-3">
        {gallery.map(item => (
          <div class="break-inside-avoid overflow-hidden rounded-brand border border-gold/20 group">
            {item.type === 'photo' ? (
              <img
                src={item.src}
                alt={item.alt}
                class="w-full block object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <video
                autoplay muted loop playsinline
                class="w-full block object-cover"
              >
                <source src={item.src} type="video/mp4" />
              </video>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────── -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="section-label">Start Your Project</span>
      <h2 class="font-heading text-navy text-4xl font-bold mt-1 mb-5">
        Ready to Add Your Project<br />
        <span class="text-gold">to This Gallery?</span>
      </h2>
      <p class="text-navy/65 mb-8 leading-relaxed">
        Contact us for a free estimate. We'll visit the site, answer your
        questions, and give you a clear picture of what to expect.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn btn-primary">Get a Free Estimate</a>
        <a href="/services" class="btn btn-outline-navy">View Our Services</a>
      </div>
    </div>
  </section>

</Layout>
