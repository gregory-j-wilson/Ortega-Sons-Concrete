---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact Ortega & Sons Concrete in Wichita, KS for a free estimate on your residential or commercial concrete project.">

  <!-- ─── PAGE HERO ─────────────────────────────────────────── -->
  <section class="relative h-64 sm:h-80 flex items-end overflow-hidden">
    <video
      autoplay muted loop playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/img/concrete-foundation-vid.mp4" type="video/mp4" />
    </video>
    <div class="page-hero-overlay absolute inset-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 w-full">
      <span class="section-label">Reach Out</span>
      <h1 class="font-heading text-cream text-4xl sm:text-5xl font-bold mt-1">Contact Us</h1>
    </div>
  </section>

  <!-- ─── CONTACT SECTION ───────────────────────────────────── -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- ── Contact Info (left) ── -->
        <div class="lg:col-span-2">
          <span class="section-label">Get in Touch</span>
          <h2 class="font-heading text-navy text-3xl font-bold mt-1 mb-4">
            Let's Talk About<br />Your Project
          </h2>
          <p class="text-navy/65 text-sm leading-relaxed mb-8">
            Whether you have a quick question or you're ready to schedule an
            estimate, we're easy to reach. We typically respond within one
            business day.
          </p>

          <ul class="space-y-6">
            <li class="flex gap-4">
              <div class="icon-box flex-shrink-0">
                <svg class="w-5 h-5 text-beige" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z" />
                </svg>
              </div>
              <div>
                <p class="font-heading text-xs uppercase tracking-widest text-gold mb-1">Phone</p>
                <a href="tel:8327691329" class="text-navy font-semibold hover:text-gold transition-colors">
                  (832) 769-1329
                </a>
                <p class="text-navy/50 text-xs mt-1">Mon–Fri, 7am – 5pm</p>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="icon-box flex-shrink-0">
                <svg class="w-5 h-5 text-beige" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-heading text-xs uppercase tracking-widest text-gold mb-1">Email</p>
                <a href="mailto:ortegaandsonsconcrete@gmail.com" class="text-navy font-semibold hover:text-gold transition-colors text-sm">
                  ortegaandsonsconcrete@gmail.com
                </a>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="icon-box flex-shrink-0">
                <svg class="w-5 h-5 text-beige" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-heading text-xs uppercase tracking-widest text-gold mb-1">Service Area</p>
                <p class="text-navy font-semibold text-sm">Wichita, KS &amp; Surrounding Communities</p>
                <p class="text-navy/50 text-xs mt-1">Sedgwick County &amp; beyond</p>
              </div>
            </li>

            <li class="flex gap-4">
              <div class="icon-box flex-shrink-0">
                <svg class="w-5 h-5 text-beige" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <p class="font-heading text-xs uppercase tracking-widest text-gold mb-1">Licensed, Bonded &amp; Insured</p>
                <p class="text-navy font-semibold text-sm">Licensed in the City of Wichita &mdash; #2644</p>
                
              </div>
            </li>
          </ul>
        </div>

        <!-- ── Contact Form (right) ── -->
        <div class="lg:col-span-3">
          <div class="brand-card bg-white p-8 sm:p-10">
            <h3 class="font-heading text-navy text-2xl font-bold mb-2">Request a Free Estimate</h3>
            <p class="text-navy/55 text-sm mb-7">Fill out the form below and we'll be in touch to schedule your on-site estimate.</p>

            <form action="#" method="POST" class="space-y-5">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="first-name" class="form-label">First Name *</label>
                  <input type="text" id="first-name" name="first_name" required
                    placeholder="Eleazar" class="form-input" />
                </div>
                <div>
                  <label for="last-name" class="form-label">Last Name *</label>
                  <input type="text" id="last-name" name="last_name" required
                    placeholder="Ortega" class="form-input" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="email" class="form-label">Email *</label>
                  <input type="email" id="email" name="email" required
                    placeholder="you@example.com" class="form-input" />
                </div>
                <div>
                  <label for="phone" class="form-label">Phone</label>
                  <input type="tel" id="phone" name="phone"
                    placeholder="(316) 000-0000" class="form-input" />
                </div>
              </div>

              <div>
                <label for="project-type" class="form-label">Project Type *</label>
                <select id="project-type" name="project_type" required class="form-input">
                  <option value="" disabled selected>Select a project type</option>
                  <option value="driveway">Residential Driveway</option>
                  <option value="patio">Patio / Walkway</option>
                  <option value="garage">Garage / Shop Floor</option>
                  <option value="foundation">Foundation / Slab</option>
                  <option value="commercial-parking">Commercial Parking Lot</option>
                  <option value="commercial-slab">Commercial Slab / Floor</option>
                  <option value="repair">Concrete Repair</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label for="address" class="form-label">Project Address</label>
                <input type="text" id="address" name="address"
                  placeholder="123 Main St, Wichita, KS" class="form-input" />
              </div>

              <div>
                <label for="message" class="form-label">Project Details *</label>
                <textarea id="message" name="message" rows="5" required
                  placeholder="Tell us about your project — size, timeline, any specific requirements..."
                  class="form-input resize-none"></textarea>
              </div>

              <div>
                <label for="how-heard" class="form-label">How Did You Hear About Us?</label>
                <select id="how-heard" name="how_heard" class="form-input">
                  <option value="" disabled selected>Select one</option>
                  <option value="referral">Friend or Family Referral</option>
                  <option value="google">Google Search</option>
                  <option value="facebook">Facebook</option>
                  <option value="yard-sign">Yard Sign</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="pt-2">
                <button type="submit" class="btn btn-primary w-full text-center">
                  Submit Request
                </button>
                <p class="text-navy/40 text-xs text-center mt-3">
                  We'll respond within 1 business day. No spam, ever.
                </p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── MAP PLACEHOLDER ───────────────────────────────────── -->
  <section class="bg-cream border-t border-navy/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="text-center mb-8">
        <span class="section-label">Find Us</span>
        <h2 class="font-heading text-navy text-3xl font-bold mt-1">Proudly Serving Wichita, KS</h2>
      </div>
      <div class="rounded-brand overflow-hidden border border-navy">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3158.459372128841!2d-97.34098962461094!3d37.6619123720141!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x87bae408e3e98541%3A0x26181f40603bd14f!2s1717%20S%20Main%20St%2C%20Wichita%2C%20KS%2067213!5e0!3m2!1sen!2sus!4v1775591430550!5m2!1sen!2sus"
          width="100%"
          height="420"
          style="border:0; display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

</Layout>
