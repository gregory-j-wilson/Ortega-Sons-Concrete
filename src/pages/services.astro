---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    img: '/img/criss-cross-driveway.jpeg',
    category: 'Residential',
    title: 'Driveways',
    desc: 'From standard broom-finish slabs to stamped and stained decorative driveways, we pour driveways that hold up to Kansas weather and heavy vehicle traffic. Proper base prep and reinforcement on every job.',
    features: ['Single & double-wide', 'Stamped & stained finishes', 'Apron replacement', 'Expansion joints included'],
  },
  {
    img: '/img/hexagon-back-porch.jpeg',
    category: 'Residential',
    title: 'Patios &amp; Walkways',
    desc: 'Transform your backyard into a functional outdoor living space. We work with your landscaping layout to design and pour custom patios, sidewalks, and connecting walkways.',
    features: ['Custom shapes & borders', 'Exposed aggregate options', 'Step construction', 'Broom or smooth finish'],
  },
  {
    img: '/img/making-garage-driveway.jpeg',
    category: 'Residential',
    title: 'Garage &amp; Shop Floors',
    desc: 'A properly prepared and poured garage floor makes all the difference. We handle sub-grade prep, vapor barriers, reinforcement, and finishing so you get a floor that won\'t crack or heave.',
    features: ['Vapor barrier installation', 'Rebar & wire mesh', 'Control joint planning', 'Smooth or broom finish'],
  },
  {
    img: '/img/laying-concrete-cones.jpeg',
    category: 'Commercial',
    title: 'Parking Lots &amp; Lots',
    desc: 'Commercial concrete parking areas designed for heavy vehicle loads and long-term durability. We coordinate with general contractors and work within project schedules.',
    features: ['ADA-compliant curb cuts', 'Reinforced for heavy loads', 'Line prep & marking ready', 'Phased pours available'],
  },
  {
    img: '/img/concrete-foundation-bars.jpeg',
    category: 'Commercial',
    title: 'Foundations &amp; Slabs',
    desc: 'Concrete foundations and flatwork for new construction, additions, and outbuildings. We work from engineered plans and coordinate with your framing crew.',
    features: ['Residential & light commercial', 'Engineered plan review', 'Slab-on-grade & stem wall', 'Anchor bolt placement'],
  },
  {
    img: '/img/driveway-dirt.jpeg',
    category: 'Specialty',
    title: 'Concrete Repair &amp; Replacement',
    desc: 'Cracked, sunken, or deteriorated concrete? We assess the root cause and provide repair or full-replacement solutions to restore safety and appearance.',
    features: ['Crack repair & sealing', 'Mudjacking assessment', 'Partial & full slab replacement', 'Trip hazard removal'],
  },
];

const process = [
  { step: '01', title: 'Free Estimate', body: 'We come to you, measure the job, and give you a written estimate — no pressure, no guesswork.' },
  { step: '02', title: 'Site Prep', body: 'We excavate, grade, and compact the sub-base. This is where quality starts — a good pour is only as good as what\'s underneath.' },
  { step: '03', title: 'Forms &amp; Reinforcement', body: 'We set forms to grade, install rebar or wire mesh as needed, and plan control joints to manage natural cracking.' },
  { step: '04', title: 'Pour &amp; Finish', body: 'Concrete is placed, screed, and finished to the specified texture. Our crew works efficiently to get the right finish before the concrete sets.' },
  { step: '05', title: 'Cure &amp; Cleanup', body: 'We apply curing compound as needed, strip forms, and leave your site clean. Final inspection walk-through with you before we leave.' },
];
---

<Layout title="Services" description="Commercial and residential concrete services in Wichita, KS — driveways, patios, foundations, parking lots, and more.">

  <!-- ─── PAGE HERO ─────────────────────────────────────────── -->
  <section class="relative h-72 sm:h-96 flex items-end overflow-hidden">
    <video
      autoplay muted loop playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/img/smoothing-concrete.mp4" type="video/mp4" />
    </video>
    <div class="page-hero-overlay absolute inset-0"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 w-full">
      <span class="section-label">What We Offer</span>
      <h1 class="font-heading text-cream text-4xl sm:text-5xl font-bold mt-1">Our Services</h1>
    </div>
  </section>

  <!-- ─── SERVICES GRID ─────────────────────────────────────── -->
  <section class="py-20 bg-cream-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="section-label">Residential &amp; Commercial</span>
        <h2 class="font-heading text-navy text-4xl font-bold mt-1">
          Concrete Work Done Right
        </h2>
        <p class="text-navy/60 mt-3 max-w-xl mx-auto text-sm">
          We handle the full scope of concrete flatwork — from small residential
          sidewalks to large commercial pours.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(s => (
          <div class="brand-card bg-white flex flex-col group">
            <div class="overflow-hidden rounded-t-brand">
              <img
                src={s.img}
                alt={s.title}
                class="project-img group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-7 flex flex-col flex-1">
              <span class="font-heading text-xs uppercase tracking-widest text-gold mb-1">{s.category}</span>
              <h3 class="font-heading text-navy text-xl font-semibold mb-3" set:html={s.title} />
              <p class="text-navy/65 text-sm leading-relaxed mb-5 flex-1">{s.desc}</p>
              <ul class="space-y-1.5 mt-auto">
                {s.features.map(f => (
                  <li class="flex items-center gap-2 text-sm text-navy/70">
                    <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── OUR PROCESS ───────────────────────────────────────── -->
  <section class="py-20 bg-navy relative overflow-hidden">
    <video
      autoplay muted loop playsinline
      class="absolute inset-0 w-full h-full object-cover opacity-10"
    >
      <source src="/img/concrete-wood.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-navy/70"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="section-label">How It Works</span>
        <h2 class="font-heading text-cream text-4xl font-bold mt-1">Our Process</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {process.map(p => (
          <div class="brand-card--light p-6 text-center">
            <div class="font-heading text-4xl font-bold text-beige mb-3">{p.step}</div>
            <h3 class="font-heading text-cream text-base font-semibold mb-3" set:html={p.title} />
            <p class="text-cream/60 text-xs leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────── -->
  <section class="py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="section-label">Get Started</span>
      <h2 class="font-heading text-navy text-4xl font-bold mt-1 mb-5">
        Ready for Your Estimate?
      </h2>
      <p class="text-navy/65 mb-8 leading-relaxed">
        Give us a call or fill out our contact form and we'll schedule a time
        to come out, measure, and provide a detailed written estimate — free of charge.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="btn btn-primary">Request a Free Quote</a>
        <a href="/projects" class="btn btn-outline-navy">See Our Projects</a>
      </div>
    </div>
  </section>

</Layout>
